@{
    var presets = (Array)ViewBag.Presets;
    var fates   = (Array)ViewBag.Fates;
    var pacings = (Array)ViewBag.Pacings;
    var models  = (Array)ViewBag.Models;
    var defaultModel = (string)ViewBag.DefaultModel;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Новый Мир</h1>
    <small class="text-muted">Шаг 1 / N — заголовок Мира</small>
</div>

<form id="form-generate" class="mb-4">
    <style>
        .fate-chip.fate-maxed:not(:hover) { opacity: 0.5; }
        .fate-chip.fate-maxed:hover { background: var(--bs-danger-bg-subtle, #f8d7da); border-color: var(--bs-danger, #dc3545); color: var(--bs-danger, #dc3545); cursor: not-allowed; }
    </style>
    <div class="mb-3">
        <label class="form-label">Пожелания к миру <small class="text-muted">(свободный текст; чипы ниже выбираются независимо)</small></label>
        <textarea id="user-hint" class="form-control" rows="3"
                  placeholder="Опиши, какой мир хочешь. Можно оставить пустым — будет сюрприз."></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Пресет стиля (необязательно)</label>
        <div id="preset-chips" class="d-flex flex-wrap gap-2">
            @foreach (dynamic p in presets)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm preset-chip"
                        data-key="@p.key" data-hint="@p.hint">@p.label</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" id="preset-clear">× очистить</button>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Тон судьбы <small class="text-muted">(0–2, тип переживания, влияет на всю [Историю])</small></label>
        <div id="fate-chips" class="d-flex flex-wrap gap-2">
            @foreach (dynamic f in fates)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm fate-chip"
                        data-key="@f.key" title="@f.hint">@f.emoji&nbsp;@f.label</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" id="fate-clear">× очистить</button>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Темп завязки <small class="text-muted">(точка входа и ритм начала [Истории])</small></label>
        <div id="pacing-chips" class="d-flex flex-wrap gap-2">
            @foreach (dynamic p in pacings)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm pacing-chip"
                        data-key="@p.key" title="@p.hint">@p.emoji&nbsp;@p.label</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" id="pacing-clear">× очистить</button>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Модель <small class="text-muted">(сверху — лучше для нашей задачи)</small></label>
        <select id="model" class="form-select">
            @foreach (dynamic m in models)
            {
                var label = $"{m.name} · {m.family}" + (string.IsNullOrEmpty((string?)m.note) ? "" : $" — {m.note}");
                if (m.name == defaultModel)
                {
                    <option value="@m.name" selected>@label</option>
                }
                else
                {
                    <option value="@m.name">@label</option>
                }
            }
        </select>
    </div>

    <div class="alert alert-light border small mb-3" id="preview-line">
        <span class="text-muted">В ИИ уйдёт:</span> <span id="preview-content" class="text-muted">(ничего не выбрано — будет сюрприз)</span>
    </div>

    <button type="submit" class="btn btn-primary" id="btn-generate">
        Создать варианты
    </button>
    <span id="status" class="ms-3 text-muted"></span>
</form>

<div id="options" class="row g-3"></div>

@section Scripts {
    <script>
        (function () {
            const presetChips = document.querySelectorAll('.preset-chip');
            const presetClear = document.getElementById('preset-clear');
            const fateChips = document.querySelectorAll('.fate-chip');
            const fateClear = document.getElementById('fate-clear');
            const pacingChips = document.querySelectorAll('.pacing-chip');
            const pacingClear = document.getElementById('pacing-clear');
            const hintEl = document.getElementById('user-hint');
            const modelEl = document.getElementById('model');
            const form = document.getElementById('form-generate');
            const btn = document.getElementById('btn-generate');
            const statusEl = document.getElementById('status');
            const optionsEl = document.getElementById('options');

            let selectedPreset = null;
            let selectedFates = [];
            let selectedPacing = null;
            let worldId = null;
            let draftId = null;

            function updateActiveChip(chips, selectedKey) {
                chips.forEach(c => {
                    if (c.dataset.key === selectedKey) {
                        c.classList.remove('btn-outline-secondary');
                        c.classList.add('btn-secondary');
                    } else {
                        c.classList.add('btn-outline-secondary');
                        c.classList.remove('btn-secondary');
                    }
                });
            }

            function updateActiveChipsMulti(chips, selectedKeys) {
                const set = new Set(selectedKeys);
                const full = selectedKeys.length >= 2;
                chips.forEach(c => {
                    if (set.has(c.dataset.key)) {
                        c.classList.remove('btn-outline-secondary', 'fate-maxed');
                        c.classList.add('btn-secondary');
                    } else {
                        c.classList.remove('btn-secondary');
                        c.classList.add('btn-outline-secondary');
                        if (full) c.classList.add('fate-maxed');
                        else c.classList.remove('fate-maxed');
                    }
                });
            }

            const previewContent = document.getElementById('preview-content');

            function labelOf(chips, key) {
                for (const c of chips) if (c.dataset.key === key) return c.textContent.trim();
                return key;
            }

            function updatePreview() {
                const parts = [];
                if (selectedPreset) parts.push(`<b>стиль:</b> ${labelOf(presetChips, selectedPreset)}`);
                if (selectedFates.length) parts.push(`<b>судьба:</b> ${selectedFates.map(k => labelOf(fateChips, k)).join(' + ')}`);
                if (selectedPacing) parts.push(`<b>темп:</b> ${labelOf(pacingChips, selectedPacing)}`);
                const hint = hintEl.value.trim();
                if (hint) parts.push(`<b>пожелания:</b> «${escapeHtml(hint)}»`);
                previewContent.innerHTML = parts.length
                    ? parts.join(' · ')
                    : '(ничего не выбрано — будет сюрприз)';
                previewContent.className = parts.length ? '' : 'text-muted';
            }

            presetChips.forEach(chip => {
                chip.addEventListener('click', () => {
                    selectedPreset = chip.dataset.key;
                    updateActiveChip(presetChips, selectedPreset);
                    updatePreview();
                });
            });
            presetClear.addEventListener('click', () => {
                selectedPreset = null;
                updateActiveChip(presetChips, null);
                updatePreview();
            });

            fateChips.forEach(chip => {
                chip.addEventListener('click', () => {
                    const key = chip.dataset.key;
                    const idx = selectedFates.indexOf(key);
                    if (idx >= 0) {
                        selectedFates.splice(idx, 1);
                    } else if (selectedFates.length < 2) {
                        selectedFates.push(key);
                    }
                    updateActiveChipsMulti(fateChips, selectedFates);
                    updatePreview();
                });
            });
            fateClear.addEventListener('click', () => {
                selectedFates = [];
                updateActiveChipsMulti(fateChips, []);
                updatePreview();
            });

            pacingChips.forEach(chip => {
                chip.addEventListener('click', () => {
                    selectedPacing = chip.dataset.key;
                    updateActiveChip(pacingChips, selectedPacing);
                    updatePreview();
                });
            });
            pacingClear.addEventListener('click', () => {
                selectedPacing = null;
                updateActiveChip(pacingChips, null);
                updatePreview();
            });

            hintEl.addEventListener('input', updatePreview);

            async function ensureWorld() {
                if (worldId) return worldId;
                const r = await fetch('/api/worlds', { method: 'POST' });
                if (!r.ok) throw new Error('Не удалось создать мир');
                const j = await r.json();
                worldId = j.id;
                return worldId;
            }

            function renderOptions(options) {
                optionsEl.innerHTML = '';
                options.forEach((opt, i) => {
                    const col = document.createElement('div');
                    col.className = 'col-md-4';
                    col.innerHTML = `
                        <div class="card h-100">
                          <div class="card-body d-flex flex-column">
                            <h5 class="card-title">${escapeHtml(opt.name)}</h5>
                            <p class="card-text flex-grow-1">${escapeHtml(opt.tagline)}</p>
                            <button class="btn btn-success mt-3" data-idx="${i}">Выбрать</button>
                          </div>
                        </div>`;
                    col.querySelector('button').addEventListener('click', () => approve(i));
                    optionsEl.appendChild(col);
                });
            }

            function escapeHtml(s) {
                return String(s).replace(/[&<>"']/g, c =>
                    ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
            }

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                btn.disabled = true;
                statusEl.textContent = 'Думаю…';
                optionsEl.innerHTML = '';
                try {
                    const id = await ensureWorld();
                    const body = {
                        userHint: hintEl.value.trim() || null,
                        preset: selectedPreset,
                        fates: selectedFates.length > 0 ? selectedFates : null,
                        pacing: selectedPacing,
                        model: modelEl.value
                    };
                    const t0 = performance.now();
                    const r = await fetch(`/api/worlds/${id}/header/generate`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(body)
                    });
                    const elapsed = ((performance.now() - t0) / 1000).toFixed(1);
                    if (!r.ok) {
                        const t = await r.text();
                        throw new Error(`HTTP ${r.status}: ${t}`);
                    }
                    const j = await r.json();
                    draftId = j.draftId;
                    statusEl.textContent = `Готово за ${elapsed} с · модель ${j.model}` +
                        (j.durationMs ? ` · ИИ ${(j.durationMs/1000).toFixed(1)} с` : '');
                    renderOptions(j.options);
                } catch (err) {
                    statusEl.innerHTML = `<span class="text-danger">${escapeHtml(err.message)}</span>`;
                } finally {
                    btn.disabled = false;
                }
            });

            async function approve(idx) {
                if (!worldId || !draftId) return;
                statusEl.textContent = 'Сохраняю…';
                try {
                    const r = await fetch(`/api/worlds/${worldId}/header/${draftId}/approve`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ chosenIndex: idx })
                    });
                    if (!r.ok) {
                        const t = await r.text();
                        throw new Error(`HTTP ${r.status}: ${t}`);
                    }
                    window.location.href = `/Worlds/${worldId}`;
                } catch (err) {
                    statusEl.innerHTML = `<span class="text-danger">${escapeHtml(err.message)}</span>`;
                }
            }
        })();
    </script>
}
